# Copy this file to .env for local development only.
# Real values must be configured in the Netlify dashboard (Site settings > Environment
# variables) for production/preview deploys — never commit actual secrets to this repo.

# OpenAI API key used by netlify/functions/chat.js to answer resume questions.
OPENAI_API_KEY=sk-your-openai-api-key

# Upstash Redis REST credentials used for rate limiting the chat function.
# Create a free database at https://console.upstash.com/ and copy the REST URL/token.
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token
